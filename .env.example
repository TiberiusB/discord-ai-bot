# Copy to .env and fill in. Never commit .env.

# Discord bot token from the Developer Portal (Bot -> Reset Token).
DISCORD_TOKEN=

# Ollama HTTP endpoint (local).
OLLAMA_HOST=http://127.0.0.1:11434

# Primary lab guild (server) ID. Right-click the server -> Copy Server ID
# (Developer Mode must be enabled in Discord settings).
GUILD_ID=

# Comma-separated Discord role IDs allowed to run admin slash commands.
# The guild owner is always allowed.
ADMIN_ROLE_IDS=
